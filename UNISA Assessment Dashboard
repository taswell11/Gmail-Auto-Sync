              }
            ]
          },
          {
            code: "PVL3701",
            name: "Property Law",
            color: "bg-teal-500",
            lightColor: "bg-teal-50",
            textColor: "text-teal-700",
            assessments: [
              {
                id: "pvl3701-a1",
                name: "Assessment 1",
                opened: "2026-03-09T13:00:00",
                openedDisplay: "Monday, 9 March 2026, 1:00 PM",
                due: "2026-04-01T13:00:00",
                dueDisplay: "Wednesday, 1 April 2026, 1:00 PM",
