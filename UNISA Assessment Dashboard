              }
            ]
          },
          {
            code: "PVL3703",
            name: "Law of Delict",
            color: "bg-rose-500",
            lightColor: "bg-rose-50",
            textColor: "text-rose-700",
            assessments: [
              {
                id: "pvl3703-a1",
                name: "Assessment 1",
                opened: "2026-02-03T08:00:00",
                openedDisplay: "Tuesday, 3 February 2026, 8:00 AM",
                due: "2026-03-24T14:00:00",
                dueDisplay: "Tuesday, 24 March 2026, 2:00 PM",
                files: []
              },
              {
                id: "pvl3703-a2",
                name: "Assessment 2",
                opened: "2026-03-03T08:00:00",
                openedDisplay: "Tuesday, 3 March 2026, 8:00 AM",
                due: "2026-04-21T14:00:00",
                dueDisplay: "Tuesday, 21 April 2026, 2:00 PM",
                files: []
              }
            ]
          }
        ];

        // --- Components ---
        const LocalFileLink = ({ file }) => {
          const [copied, setCopied] = useState(false);

          const handleCopy = (e) => {
            e.preventDefault();
            const textArea = document.createElement("textarea");
            textArea.value = file.path;
            document.body.appendChild(textArea);
            textArea.select();
            try {
              document.execCommand('copy');
              setCopied(true);
              setTimeout(() => setCopied(false), 2000);
            } catch (err) {
              console.error('Failed to copy', err);
            }
            document.body.removeChild(textArea);
          };

          return (
            <button 
              onClick={handleCopy}
              className="mt-2 w-full flex items-center justify-between p-2.5 bg-white border border-slate-200 rounded-lg hover:border-blue-400 hover:bg-blue-50 transition-colors group text-left"
              title={file.path}
            >
              <div className="flex items-center min-w-0 flex-1">
                <FileText className="w-4 h-4 text-slate-400 group-hover:text-blue-500 flex-shrink-0 mr-3" />
                <div className="truncate pr-4">
                  <p className="text-sm font-medium text-slate-700 group-hover:text-blue-700 truncate">
                    {file.name}
                  </p>
                  <p className="text-xs text-slate-400 truncate">
                    Click to copy file path
                  </p>
                </div>
              </div>
              <div className="flex-shrink-0">
                {copied ? (
                  <span className="flex items-center text-xs font-medium text-emerald-600 bg-emerald-50 px-2 py-1 rounded">
                    <Check className="w-3 h-3 mr-1" /> Copied
                  </span>
                ) : (
                  <Copy className="w-4 h-4 text-slate-400 group-hover:text-blue-500" />
                )}
              </div>
            </button>
          );
        };

        function App() {
          const [currentDate, setCurrentDate] = useState(new Date());

          const getStatus = (opened, due) => {
            const openDate = new Date(opened);
            const dueDate = new Date(due);
            const now = new Date();
            
            const daysRemaining = Math.ceil((dueDate - now) / (1000 * 60 * 60 * 24));

            if (now > dueDate) return { label: 'Closed', color: 'bg-slate-100 text-slate-600 border-slate-200', urgent: false };
            if (now < openDate) return { label: 'Upcoming', color: 'bg-slate-100 text-slate-600 border-slate-200', urgent: false };
            
            if (daysRemaining <= 3) return { label: 'Due Soon', color: 'bg-rose-100 text-rose-700 border-rose-200', urgent: true, days: daysRemaining };
            return { label: 'Active', color: 'bg-emerald-100 text-emerald-700 border-emerald-200', urgent: false, days: daysRemaining };
          };

          // Flatten and sort assessments for the timeline chart
          const timelineAssessments = useMemo(() => {
            let items = [];
            courseData.forEach(course => {
              course.assessments.forEach(assessment => {
                items.push({
                  ...assessment,
                  courseCode: course.code,
                  courseName: course.name,
                  courseColor: course.color,
                  dueDateObj: new Date(assessment.due)
                });
              });
            });
            // Sort chronologically by due date
            return items.sort((a, b) => a.dueDateObj - b.dueDateObj);
          }, []);

          return (
            <div className="min-h-screen bg-slate-50 font-sans text-slate-900 pb-12">
              <header className="bg-white border-b border-slate-200 sticky top-0 z-10">
                <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                  <div className="flex justify-between items-center h-16">
                    <div className="flex items-center">
                      <div className="bg-blue-600 p-2 rounded-lg mr-3">
                        <GraduationCap className="w-6 h-6 text-white" />
                      </div>
                      <div>
                        <h1 className="text-xl font-bold text-slate-900">UNISA Law Dashboard</h1>
                        <p className="text-xs text-slate-500">Year 3 • Semester 1 • 2026</p>
                      </div>
                    </div>
                  </div>
                </div>
              </header>

              <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                <div className="bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between">
                  <div>
                    <h2 className="text-lg font-semibold text-slate-800">Assessment Overview</h2>
                    <p className="text-sm text-slate-500 mt-1">Keep track of your upcoming due dates and required files.</p>
                  </div>
                  <div className="mt-4 sm:mt-0 flex gap-2">
                    <span className="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-emerald-100 text-emerald-800">
                      Active Assessments
                    </span>
                  </div>
                </div>

                {/* --- Timeline Chart Section --- */}
                <div className="bg-white rounded-xl shadow-sm border border-slate-200 p-6 mb-8">
                  <div className="flex items-center mb-6">
                    <TrendingUp className="w-5 h-5 text-blue-500 mr-2" />
                    <h2 className="text-lg font-semibold text-slate-800">Deadlines Timeline</h2>
                  </div>
                  
                  <div className="relative w-full">
                    {/* The horizontal connecting line */}
                    <div className="absolute top-4 left-0 w-full h-0.5 bg-slate-200 z-0 rounded-full"></div>
                    
                    {/* Scrollable container for the timeline items */}
                    <div className="flex overflow-x-auto pb-4 space-x-6 hide-scrollbar relative z-10 snap-x">
                      {timelineAssessments.map((item, idx) => {
                        const status = getStatus(item.opened, item.due);
                        const isPast = new Date() > item.dueDateObj;
                        
                        // Format the date nicely for the chart
                        const formattedDate = item.dueDateObj.toLocaleDateString('en-GB', { 
                          day: 'numeric', 
                          month: 'short' 
                        });

                        return (
                          <div key={`${item.courseCode}-${item.id}`} className="flex-shrink-0 w-48 flex flex-col items-center snap-start">
                            {/* Dot on the timeline */}
                            <div className={`w-4 h-4 rounded-full border-4 border-white shadow-sm mb-4 ${isPast ? 'bg-slate-300' : item.courseColor}`}></div>
                            
                            {/* Card Details */}
                            <div className={`w-full p-4 rounded-lg border ${isPast ? 'bg-slate-50 border-slate-100 opacity-60' : 'bg-white border-slate-200 shadow-sm'} flex flex-col items-center text-center transition-transform hover:-translate-y-1`}>
                              <span className={`inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider ${isPast ? 'bg-slate-400' : item.courseColor} text-white mb-2`}>
                                {item.courseCode}
                              </span>
                              <h4 className="font-bold text-sm text-slate-800 mb-1 leading-tight">{item.name}</h4>
                              <p className={`text-xs font-semibold mb-2 ${status.urgent ? 'text-rose-600' : 'text-slate-600'}`}>
                                {formattedDate}
                              </p>
                              <span className={`text-[10px] px-2 py-0.5 rounded-full border font-medium ${status.color}`}>
                                {status.label} {status.days && `(${status.days}d)`}
                              </span>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                </div>
                {/* --- End Timeline Chart Section --- */}

                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                  {courseData.map((course) => (
                    <div key={course.code} className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">
                      <div className={`${course.lightColor} px-5 py-4 border-b border-slate-100 flex items-start justify-between`}>
                        <div>
                          <span className={`inline-block px-2 py-1 rounded text-xs font-bold ${course.color} text-white mb-2`}>
                            {course.code}
                          </span>
                          <h3 className={`font-semibold text-lg ${course.textColor}`}>
                            {course.name}
                          </h3>
                        </div>
                        <BookOpen className={`w-5 h-5 ${course.textColor} opacity-50`} />
                      </div>

                      <div className="p-5 flex-1 bg-white">
                        {course.assessments.length === 0 ? (
                          <div className="text-center py-8 text-slate-400">
                            <p className="text-sm">No assessments listed yet.</p>
                          </div>
                        ) : (
                          <div className="space-y-6">
                            {course.assessments.map((assessment) => {
                              const status = getStatus(assessment.opened, assessment.due);
                              
                              return (
                                <div key={assessment.id} className="relative">
                                  <div className="flex items-center justify-between mb-2">
                                    <h4 className="text-sm font-bold text-slate-800 flex items-center">
                                      {assessment.name}
                                      {status.urgent && (
                                        <AlertCircle className="w-4 h-4 ml-2 text-rose-500" />
                                      )}
                                    </h4>
                                    <span className={`text-xs px-2 py-0.5 rounded-full border font-medium ${status.color}`}>
                                      {status.label} {status.days && `(${status.days}d)`}
                                    </span>
                                  </div>

                                  <div className="space-y-1.5 mb-3 bg-slate-50 rounded-lg p-3 border border-slate-100">
                                    <div className="flex items-start">
                                      <Calendar className="w-4 h-4 text-slate-400 mr-2 mt-0.5 flex-shrink-0" />
                                      <div>
                                        <p className="text-xs font-medium text-slate-500 uppercase tracking-wider">Opens</p>
                                        <p className="text-sm text-slate-700">{assessment.openedDisplay}</p>
                                      </div>
                                    </div>
                                    <div className="flex items-start mt-2">
                                      <Clock className={`w-4 h-4 mr-2 mt-0.5 flex-shrink-0 ${status.urgent ? 'text-rose-400' : 'text-slate-400'}`} />
                                      <div>
                                        <p className={`text-xs font-medium uppercase tracking-wider ${status.urgent ? 'text-rose-500' : 'text-slate-500'}`}>
                                          Due / Closes
                                        </p>
                                        <p className={`text-sm font-medium ${status.urgent ? 'text-rose-700' : 'text-slate-700'}`}>
                                          {assessment.dueDisplay}
                                        </p>
                                      </div>
                                    </div>
                                  </div>

                                  {assessment.files && assessment.files.length > 0 && (
                                    <div className="mt-3">
                                      <p className="text-xs font-medium text-slate-500 uppercase tracking-wider mb-2 px-1">Attached Files</p>
                                      {assessment.files.map((file, idx) => (
                                        <LocalFileLink key={idx} file={file} />
                                      ))}
                                    </div>
                                  )}
                                  
                                  {course.assessments[course.assessments.length - 1].id !== assessment.id && (
                                    <hr className="mt-6 border-slate-100" />
                                  )}
                                </div>
                              );
                            })}
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </main>
            </div>
          );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
