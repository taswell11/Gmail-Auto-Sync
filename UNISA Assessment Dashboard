                    name: "Assignment 1 Semester 1 2026.pdf"
                  },
                  {
                    path: "C:\\Users\\Taswell\\My Drive (taswellsolomons@gmail.com)\\UNISA\\Year3\\MRL3701 - Insolvency Law\\MRL3701 Assignment 2 Semester 1 2026.pdf",
                    name: "Assignment 2 Semester 1 2026.pdf"
                  }
                ]
              },
              {
                id: "mrl3701-a2",
                name: "Assessment 2",
                opened: "2026-03-13T08:00:00",
                openedDisplay: "Friday, 13 March 2026, 8:00 AM",
                due: "2026-03-24T20:00:00",
                dueDisplay: "Tuesday, 24 March 2026, 8:00 PM",
                files: []
              }
            ]
          },
          {
            code: "MRL3702",
            name: "Labour Law",
            color: "bg-indigo-500",
            lightColor: "bg-indigo-50",
            textColor: "text-indigo-700",
            assessments: [
              {
                id: "mrl3702-a1",
                name: "Assessment 1",
                opened: "2026-01-01T08:00:00",
                openedDisplay: "Thursday, 1 January 2026, 8:00 AM",
                due: "2026-03-12T23:00:00",
                dueDisplay: "Thursday, 12 March 2026, 11:00 PM",
                files: []
              },
              {
